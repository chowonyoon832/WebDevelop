@page
@model ConstructionSurvey.Pages.SurveyModel
@{
    ViewData["Title"] = "설문";
}

<div class="survey-container">
    <div class="survey-intro">
        <p>최근 1~2주간 본인 상태를 기준으로 솔직하게 응답해 주세요.</p>
    </div>

    <div class="progress-bar-container">
        <div class="progress-text"><span id="answered-count">0</span> / @Model.Questions.Count 완료</div>
        <div class="progress-bar">
            <div class="progress-fill" id="progress-fill" style="width: 0%"></div>
        </div>
    </div>

    <form method="post" action="/Result" id="survey-form">
        @Html.AntiForgeryToken()

        <input type="hidden" name="WorkerName" value="@Model.WorkerName" />
        <input type="hidden" name="Company" value="@Model.Company" />
        <input type="hidden" name="Trade" value="@Model.Trade" />
        <input type="hidden" name="AccessTime" value="@Model.AccessTime" />

        @for (int i = 0; i < Model.Questions.Count; i++)
        {
            var q = Model.Questions[i];
            <div class="question-card" id="question-@q.Number">
                <div class="question-number">문항 @q.Number</div>
                <div class="question-category">[@q.Category]</div>
                <div class="question-text">@q.Text</div>
                <div class="answer-buttons">
                    <label class="answer-btn">
                        <input type="radio" name="answer_@q.Number" value="1" required />
                        <span>전혀 아니다</span>
                    </label>
                    <label class="answer-btn">
                        <input type="radio" name="answer_@q.Number" value="2" />
                        <span>별로 아니다</span>
                    </label>
                    <label class="answer-btn">
                        <input type="radio" name="answer_@q.Number" value="3" />
                        <span>약간 그렇다</span>
                    </label>
                    <label class="answer-btn">
                        <input type="radio" name="answer_@q.Number" value="4" />
                        <span>매우 그렇다</span>
                    </label>
                </div>
            </div>
        }

        <div class="submit-section">
            <button type="submit" class="submit-btn" id="submit-btn" disabled>제출하기</button>
            <p class="submit-hint" id="submit-hint">모든 문항에 응답해야 제출할 수 있습니다.</p>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/survey.js" asp-append-version="true"></script>
}
