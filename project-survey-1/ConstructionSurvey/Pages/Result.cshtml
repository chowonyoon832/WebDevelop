@page
@model ConstructionSurvey.Pages.ResultModel
@{
    ViewData["Title"] = "결과";

    string bannerClass, bannerIcon, bannerText, adviceText;
    switch (Model.Result.RiskLevel)
    {
        case ConstructionSurvey.Models.RiskLevel.Green:
            bannerClass = "result-green";
            bannerIcon = "&#10004;";
            bannerText = "안전 양호";
            adviceText = "현재 심리·신체 상태가 양호합니다. 컨디션이 좋을 때도 방심하지 말고, 오늘 하루도 안전하게 마무리하세요.";
            break;
        case ConstructionSurvey.Models.RiskLevel.Yellow:
            bannerClass = "result-yellow";
            bannerIcon = "&#9888;";
            bannerText = "주의 필요";
            adviceText = "일부 항목에서 평소보다 부담을 느끼고 계신 것으로 보입니다. 작업 중 무리하지 말고 한 템포 쉬어가셔도 괜찮습니다. 불편한 점이 있으면 현장 관리자에게 알려주세요.";
            break;
        default:
            bannerClass = "result-red";
            bannerIcon = "&#9888;";
            bannerText = "컨디션 관리 필요";
            adviceText = "현재 심리·신체적으로 부담이 큰 상태입니다. 작업 전 현장 관리자나 동료에게 컨디션을 알려주세요. 내 상태를 먼저 돌보는 것이 안전의 시작입니다.";
            break;
    }
}

<div class="result-container">
    <div class="worker-info-summary">
        <div class="info-row">
            <span class="info-label">이름</span>
            <span class="info-value">@Model.WorkerName</span>
        </div>
        <div class="info-row">
            <span class="info-label">소속업체</span>
            <span class="info-value">@Model.Company</span>
        </div>
        <div class="info-row">
            <span class="info-label">공종</span>
            <span class="info-value">@Model.Trade</span>
        </div>
        <div class="info-row">
            <span class="info-label">접속시간</span>
            <span class="info-value">@Model.AccessTime</span>
        </div>
        <div class="info-row">
            <span class="info-label">제출시간</span>
            <span class="info-value">@Model.SubmitTime</span>
        </div>
        <div class="info-row">
            <span class="info-label">소요시간</span>
            <span class="info-value">@Model.Duration</span>
        </div>
    </div>

    <div class="result-banner @bannerClass">
        <span class="result-icon">@Html.Raw(bannerIcon)</span>
        <span class="result-label">@bannerText</span>
    </div>

    <div class="result-score">
        <span class="score-number">@Model.Result.TotalScore</span>
        <span class="score-total">/ 56점</span>
    </div>

    <div class="result-gauge">
        <div class="gauge-bar">
            <div class="gauge-section gauge-green" style="width:26.2%">양호</div>
            <div class="gauge-section gauge-yellow" style="width:30.9%">주의</div>
            <div class="gauge-section gauge-red" style="width:42.9%">위험</div>
        </div>
        <div class="gauge-marker" style="left:@(((Model.Result.TotalScore - 14.0) / 42.0 * 100).ToString("F1"))%">
            <div class="marker-arrow">&#9650;</div>
        </div>
    </div>

    <div class="result-advice">
        <h3>오늘의 컨디션</h3>
        <p>@adviceText</p>
    </div>

    <a href="/" class="retry-btn">다시 검사하기</a>
</div>
