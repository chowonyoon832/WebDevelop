@page
@model ConstructionSurvey.Pages.ResultsModel
@{
    ViewData["Title"] = "결과 현황";
    // 날짜 파라미터를 유지하기 위한 헬퍼
    var dateParam = !string.IsNullOrEmpty(Model.Date) ? $"&Date={Model.Date}" : "";
    var dateOnly = !string.IsNullOrEmpty(Model.Date) ? $"?Date={Model.Date}" : "";
}

<div class="results-page">
    <h2 class="results-title">설문 결과 현황</h2>

    <!-- 날짜 필터 (달력) -->
    @if (Model.AvailableDates.Count > 0)
    {
        <div class="date-filter-bar">
            <div class="calendar-header-row">
                <span class="date-filter-label">날짜 선택</span>
                <a href="/Results@(!string.IsNullOrEmpty(Model.Filter) ? $"?Filter={Model.Filter}" : "")"
                   class="calendar-reset-btn @(string.IsNullOrEmpty(Model.Date) ? "calendar-reset-active" : "")">전체 날짜</a>
            </div>
            @if (!string.IsNullOrEmpty(Model.Date))
            {
                <div class="calendar-selected-date">선택된 날짜: <strong>@Model.Date</strong></div>
            }
            <div class="calendar-nav">
                <button type="button" class="calendar-nav-btn" id="calPrev">&lt;</button>
                <span class="calendar-month-label" id="calMonthLabel"></span>
                <button type="button" class="calendar-nav-btn" id="calNext">&gt;</button>
            </div>
            <div class="calendar-grid">
                <div class="calendar-dow">일</div>
                <div class="calendar-dow">월</div>
                <div class="calendar-dow">화</div>
                <div class="calendar-dow">수</div>
                <div class="calendar-dow">목</div>
                <div class="calendar-dow">금</div>
                <div class="calendar-dow">토</div>
            </div>
            <div class="calendar-grid" id="calDays"></div>
        </div>
    }

    <!-- 요약 카드 -->
    <div class="stats-row">
        <a href="/Results@(dateOnly)" class="stat-card stat-card-total">
            <div class="stat-number">@Model.TotalCount</div>
            <div class="stat-label">전체</div>
        </a>
        <a href="/Results?Filter=양호@(dateParam)" class="stat-card stat-card-green">
            <div class="stat-number">@Model.GreenCount</div>
            <div class="stat-label">양호</div>
        </a>
        <a href="/Results?Filter=주의@(dateParam)" class="stat-card stat-card-yellow">
            <div class="stat-number">@Model.YellowCount</div>
            <div class="stat-label">주의</div>
        </a>
        <a href="/Results?Filter=위험@(dateParam)" class="stat-card stat-card-red">
            <div class="stat-number">@Model.RedCount</div>
            <div class="stat-label">위험</div>
        </a>
    </div>

    <!-- 필터 바 -->
    <div class="filter-bar">
        <a href="/Results@(dateOnly)" class="filter-link @(string.IsNullOrEmpty(Model.Filter) ? "filter-active" : "filter-inactive")">전체</a>
        <a href="/Results?Filter=양호@(dateParam)" class="filter-link @(Model.Filter == "양호" ? "filter-active" : "filter-inactive")">양호</a>
        <a href="/Results?Filter=주의@(dateParam)" class="filter-link @(Model.Filter == "주의" ? "filter-active" : "filter-inactive")">주의</a>
        <a href="/Results?Filter=위험@(dateParam)" class="filter-link @(Model.Filter == "위험" ? "filter-active" : "filter-inactive")">위험</a>
    </div>

    @if (Model.Submissions.Count == 0)
    {
        <div class="empty-state">
            <p>아직 제출된 설문이 없습니다.</p>
        </div>
    }
    else
    {
        <!-- 결과 테이블 -->
        <div class="results-table-wrapper">
            <table class="results-table">
                <thead>
                    <tr>
                        <th>번호</th>
                        <th>이름</th>
                        <th>소속업체</th>
                        <th>공종</th>
                        <th>접속시간</th>
                        <th>제출시간</th>
                        <th>소요시간</th>
                        <th>총점</th>
                        <th>위험등급</th>
                        <th>위험 플래그</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var index = 1; }
                    @foreach (var s in Model.Submissions)
                    {
                        var rowClass = s.RiskLevel switch
                        {
                            "양호" => "risk-green",
                            "주의" => "risk-yellow",
                            "위험" => "risk-red",
                            _ => ""
                        };
                        <tr class="@rowClass">
                            <td>@index</td>
                            <td>@s.Name</td>
                            <td>@s.Company</td>
                            <td>@s.Trade</td>
                            <td>@s.AccessTime</td>
                            <td>@s.SubmitTime</td>
                            <td>@s.Duration</td>
                            <td><strong>@s.TotalScore</strong></td>
                            <td><strong>@s.RiskLevel</strong></td>
                            <td class="flags-cell">@s.CriticalFlags</td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
<script>
(function() {
    var availableDates = [@Html.Raw(string.Join(",", Model.AvailableDates.Select(d => $"\"{d}\"")))];
    var selectedDate = "@(Model.Date ?? "")";
    var currentFilter = "@(Model.Filter ?? "")";

    var availableSet = {};
    availableDates.forEach(function(d) { availableSet[d] = true; });

    // 달력 초기 월: 선택된 날짜가 있으면 그 달, 없으면 가장 최근 날짜의 달
    var initDate;
    if (selectedDate) {
        initDate = new Date(selectedDate + "T00:00:00");
    } else if (availableDates.length > 0) {
        initDate = new Date(availableDates[0] + "T00:00:00");
    } else {
        initDate = new Date();
    }

    var viewYear = initDate.getFullYear();
    var viewMonth = initDate.getMonth();

    var monthLabel = document.getElementById('calMonthLabel');
    var daysContainer = document.getElementById('calDays');
    var prevBtn = document.getElementById('calPrev');
    var nextBtn = document.getElementById('calNext');

    function pad(n) { return n < 10 ? '0' + n : '' + n; }

    function renderCalendar() {
        monthLabel.textContent = viewYear + '년 ' + (viewMonth + 1) + '월';

        var firstDay = new Date(viewYear, viewMonth, 1).getDay();
        var lastDate = new Date(viewYear, viewMonth + 1, 0).getDate();

        var html = '';

        // 빈 칸
        for (var i = 0; i < firstDay; i++) {
            html += '<div class="calendar-day calendar-day-empty"></div>';
        }

        for (var d = 1; d <= lastDate; d++) {
            var dateStr = viewYear + '-' + pad(viewMonth + 1) + '-' + pad(d);
            var hasData = availableSet[dateStr];
            var isSelected = dateStr === selectedDate;

            var cls = 'calendar-day';
            if (hasData) cls += ' calendar-day-has-data';
            if (isSelected) cls += ' calendar-day-selected';
            if (!hasData) cls += ' calendar-day-disabled';

            if (hasData) {
                var filterParam = currentFilter ? '&Filter=' + encodeURIComponent(currentFilter) : '';
                html += '<a href="/Results?Date=' + dateStr + filterParam + '" class="' + cls + '">' + d + '</a>';
            } else {
                html += '<div class="' + cls + '">' + d + '</div>';
            }
        }

        daysContainer.innerHTML = html;
    }

    prevBtn.addEventListener('click', function() {
        viewMonth--;
        if (viewMonth < 0) { viewMonth = 11; viewYear--; }
        renderCalendar();
    });

    nextBtn.addEventListener('click', function() {
        viewMonth++;
        if (viewMonth > 11) { viewMonth = 0; viewYear++; }
        renderCalendar();
    });

    renderCalendar();
})();
</script>
}
